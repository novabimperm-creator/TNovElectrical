<Window x:Class="TNovElectrical.CableTraysWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovElectrical"
             mc:Ignorable="d" Height="390" Width="400"
        d:DataContext="{d:DesignInstance local:CableTraysViewModel}"
            WindowStartupLocation="CenterScreen" 
            AllowsTransparency="True"
Background="Transparent"
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
              ResizeBorderThickness="5"
              GlassFrameThickness="0"
              CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
        Background="White"
        BorderBrush="#FF008E43"
        BorderThickness="1">
        <Grid>
            <!-- Верхняя панель (кастомный заголовок) -->
            <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Click="escButton_Click" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle2}" 
Click="HelpButton_Click" Content="?"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Лотки" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>

            </Border>

            <!-- Основное содержимое -->
            <Border Margin="0,30,0,0">
                <StackPanel VerticalAlignment="Center" Margin="5">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Text="Типы лотков в проекте:" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBox Name="textBox1" Text="{Binding types}" MinWidth="360" Margin="5" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Text="Имя типа лотка должно содержать:" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Text="с крышками:" TextAlignment="Right" Width="100" />
                        <TextBox Name="textBox2" Text="{Binding filter1}" MinWidth="150" Margin="5" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Text="с перегородками:" TextAlignment="Right" Width="100" />
                        <TextBox Name="textBox3" Text="{Binding filter2}" MinWidth="150" Margin="5" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Имена семейств крышек/перегородок" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="должны содержать:" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Text="Крышки:" TextAlignment="Right" Width="100" />
                        <TextBox Name="textBox4" Text="{Binding capname}" MinWidth="150" Margin="5" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Text="Перегородки:" TextAlignment="Right" Width="100" />
                        <TextBox Name="textBox5" Text="{Binding ptname}" MinWidth="150" Margin="5" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <CheckBox x:Name="checkBox1" IsThreeState="False" IsChecked="{Binding replace}" Content="Пересоздать элементы, если уже созданы" Margin="5" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <CheckBox x:Name="checkBox2" IsThreeState="False" IsChecked="{Binding remove}" Content="Удалить элементы без связи с лотками" Margin="5" BorderBrush="#CCCCCC"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Отмена" x:Name="escButton" IsCancel="True" Click="escButton_Click" MinWidth="60" MinHeight="25" Margin="5" />
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Применить" x:Name="acceptButton" IsDefault="True" Click="acceptButton_Click" MinWidth="120" Margin="5"/>
                    </StackPanel>

                </StackPanel>


            </Border>
        </Grid>
    </Border>
</Window>
